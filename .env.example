# Production origin — used for canonical URLs, OG tags, sitemap.xml and robots.txt.
# Defaults to https://lucasmujica.dev when unset.
NEXT_PUBLIC_SITE_URL=https://lucasmujica.dev

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX). When unset, GA4 and
# the cookie-consent banner are skipped entirely — the site runs analytics-free.
NEXT_PUBLIC_GA_ID=
